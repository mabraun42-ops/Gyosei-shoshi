                body.classList.remove('lang-mode-ja');
                deBtn.className = 'px-3 py-1 text-xs font-bold rounded-full transition-all bg-white text-navy-800 shadow-sm';
                jaBtn.className = 'px-3 py-1 text-xs font-bold rounded-full transition-all text-slate-500 hover:text-navy-800';
            }
            
            // Save preference
            localStorage.setItem('preferred_language', lang);
            
            // Recalculate fees to trigger correctly localized values
            calculateFees();
        }

        // Live calculator formula
        function calculateFees() {
            let total = 0;
            const items = document.querySelectorAll('.estimator-item');
            
            // Collect service values
            items.forEach(item => {
                if (item.checked) {
                    total += parseInt(item.value);
                }
            });

            // Add extras
            const express = document.getElementById('opt-express');
            if (express && express.checked) {
                total += parseInt(express.value);
            }

            const translation = document.getElementById('opt-translation');
            if (translation && translation.checked) {
                total += parseInt(translation.value);
            }

            // Display formatted Japanese Yen
            const totalDisplay = document.getElementById('estimated-total');
            if (totalDisplay) {
                totalDisplay.innerText = "¥" + total.toLocaleString('ja-JP');
            }
            
            return total;
        }

        // Accordion utility
        function toggleFaq(id) {
            const ans = document.getElementById(id + '-ans');
            const icon = document.getElementById(id + '-icon');
            
            if (ans && icon) {
                const isHidden = ans.classList.contains('hidden');
                
                // Hide all FAQs first for clean UI
                const allAnswers = document.querySelectorAll('[id$="-ans"]');
                const allIcons = document.querySelectorAll('[id$="-icon"]');
                allAnswers.forEach(el => el.classList.add('hidden'));
                allIcons.forEach(el => {
                    el.classList.remove('rotate-180');
                    el.classList.add('fa-chevron-down');
                });

                if (isHidden) {
                    ans.classList.remove('hidden');
                    icon.classList.add('rotate-180');
                }
            }
        }

        // Prefill contact form using calculation state
        function populateContactFormWithEstimate() {
            const total = calculateFees();
            const txtarea = document.getElementById('frm-message');
            if (txtarea && total > 0) {
                if (currentLanguage === 'ja') {
                    txtarea.value = `【料金シミュレーションお見積もり概算】\n推定合計費用: ¥${total.toLocaleString('ja-JP')}\n\nこちらのお見積内容で相談を希望します。詳しい手続きや必要書類について教えてください。`;
                } else {
                    txtarea.value = `[Kostenvoranschlag aus der Online-Simulation]\nGeschätzter Preis: ¥${total.toLocaleString('ja-JP')}\n\nIch interessiere mich für die oben ausgewählten Leistungen. Bitte kontaktieren Sie mich bezüglich der Details und Anforderungen.`;
                }
            }
        }

        // Form Submission intercept (Strictly avoiding standard alert)
        function handleFormSubmit(e) {
            e.preventDefault();
            const toast = document.getElementById('success-toast');
            if (toast) {
                toast.classList.remove('hidden');
                toast.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            
            // Clean up inputs elegantly
            document.getElementById('frm-name').value = '';
            document.getElementById('frm-email').value = '';
            document.getElementById('frm-phone').value = '';
            document.getElementById('frm-message').value = '';
            document.getElementById('frm-terms').checked = false;
        }

        // Initialize state on window load
        window.onload = function() {
            const savedLanguage = localStorage.getItem('preferred_language') || 'de';
            switchLanguage(savedLanguage);
            calculateFees();
        };
    </script>
</body>
</html>
